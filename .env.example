# ==============================================================================
# LeadOS Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and populate the values below.
# NEVER commit .env.local or actual secrets to version control.
# ==============================================================================

# [Required] Supabase Connection
# ------------------------------------------------------------------------------
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings -> API
# 3. Copy the URL and the `anon` / `public` key
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# [Required] Application Configuration
# ------------------------------------------------------------------------------
APP_ENV="development" # Set to 'production' on Vercel
VITE_APP_VERSION="1.0.0"

# [Optional] Error Tracking & Telemetry
# ------------------------------------------------------------------------------
# SENTRY_DSN="https://xxxxx@o000000.ingest.us.sentry.io/0000000"
